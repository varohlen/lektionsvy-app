{
  "name": "lektionsvy-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "@tiptap/core": "^3.22.0",
    "@tiptap/extension-bullet-list": "^3.22.0",
    "@tiptap/extension-font-size": "3.0.0-next.3",
    "@tiptap/extension-list-item": "^3.22.0",
    "@tiptap/extension-ordered-list": "^3.22.0",
    "@tiptap/extension-text-style": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@untemps/svelte-palette": "5.2.0",
    "lucide-svelte": "^0.577.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
